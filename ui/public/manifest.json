{
  "name": "Whirlpool Insights",
  "short_name": "Whirlpool Insights",
  "description": "Manage your Whirlpool Insights at fingertips.",
  "id": "https://whirlpool.scoptanalytics.in/?v=1.0.0",
  "start_url": "/?v=1.0.0",
  "version": "1.0.0",
  "orientation": "any",
  "display": "standalone",
  "theme_color": "#ffffff",
  "background_color": "#ffffff",
  "icons": [
    {
      "src": "/assets/icons/favicon.ico",
      "type": "image/x-icon",
      "sizes": "32x32"
    },
    {
      "src": "/assets/icons/icon-192.png",
      "type": "image/png",
      "sizes": "192x192"
    },
    {
      "src": "/assets/icons/icon-512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/icon-192-maskable.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "maskable"
    },
    {
      "src": "/assets/icons/icon-512-maskable.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/assets/screenshots/1.png",
      "sizes": "1290x2796",
      "type": "image/png"
    },
    {
      "src": "/assets/screenshots/2.png",
      "sizes": "1290x2796",
      "type": "image/png"
    },
    {
      "src": "/assets/screenshots/3.png",
      "sizes": "1290x2796",
      "type": "image/png"
    }
  ],
  "display_override": ["window-controls-overlay"],
  "protocol_handlers": [
    {
      "protocol": "web+whirlpoolpdi",
      "url": "/ops/new-inspection/unit/%s"
    },
    {
      "protocol": "web+whirlpoolpdi",
      "url": "/ops/new-inspection?barcode=%s"
    }
  ],
  "url_handlers": [
    {
      "origin": "https://whirlpool.scoptanalytics.in"
    }
  ]
}
