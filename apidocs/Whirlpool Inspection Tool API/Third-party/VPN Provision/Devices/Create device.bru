meta {
  name: Create device
  type: http
  seq: 1
}

post {
  url: {{vpn_provisioner_url}}/v1/devices
  body: json
  auth: bearer
}

auth:bearer {
  token: {{vpn_provisioner_token}}
}

body:json {
  {
    "user_name": "Whirlpool User 01",
