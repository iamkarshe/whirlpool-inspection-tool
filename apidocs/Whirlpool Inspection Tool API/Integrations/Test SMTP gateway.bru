meta {
  name: Test SMTP gateway
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/integrations/smtp/test-gateway
  body: json
  auth: inherit
}

body:json {
  {
    "host": "mailhost.whirlpool.com",
    "port": 25,
    "encryption": "starttls",
    "tls_verify": true,
    "auth_enabled": false,
    "to_email": "utkarsh2point0@gmail.com",
    "from_email": "pdiapp@whirlpool.in",
    "from_name": "Whirlpool Inspection",
    "timeout_seconds": 30
  }
}
