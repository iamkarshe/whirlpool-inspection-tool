meta {
  name: SMTP update
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/api/integrations/smtp
  body: json
  auth: inherit
}

body:json {
  {
    "provider": "aws_ses",
    "host": "email-smtp.ap-south-1.amazonaws.com",
    "port": 587,
    "encryption": "starttls",
    "username": "AKIA...",
    "password": "your-smtp-password",
    "from_email": "noreply@example.com",
    "from_name": "Whirlpool Inspection",
    "timeout_seconds": 30
  }
}
