#!/usr/bin/env bash
set -euo pipefail

PEER_NAME="warehouse-user"
PEER_IP="10.44.0.20"
WG_DIR="/etc/wireguard"
PEER_DIR="$WG_DIR/peers/$PEER_NAME"
ENDPOINT_HOST="whirlpool-pdi-vpn.scoptanalytics.in"
ENDPOINT_PORT="51820"

if [ ! -f "$WG_DIR/server_public.key" ]; then
  echo "Missing WireGuard server public key: $WG_DIR/server_public.key"
  exit 1
fi

SERVER_PUBLIC_KEY="$(cat "$WG_DIR/server_public.key")"

sudo mkdir -p "$PEER_DIR"
sudo chmod 700 "$PEER_DIR"

if [ ! -f "$PEER_DIR/private.key" ]; then
  wg genkey | sudo tee "$PEER_DIR/private.key" | wg pubkey | sudo tee "$PEER_DIR/public.key" > /dev/null
  sudo chmod 600 "$PEER_DIR/private.key"
fi

PEER_PRIVATE_KEY="$(sudo cat "$PEER_DIR/private.key")"
PEER_PUBLIC_KEY="$(sudo cat "$PEER_DIR/public.key")"

if ! sudo grep -q "$PEER_PUBLIC_KEY" "$WG_DIR/wg0.conf"; then
  sudo tee -a "$WG_DIR/wg0.conf" > /dev/null <<WGPEER

[Peer]
# $PEER_NAME
PublicKey = $PEER_PUBLIC_KEY
AllowedIPs = $PEER_IP/32
WGPEER
fi

sudo tee "$PEER_DIR/$PEER_NAME.conf" > /dev/null <<WGCLIENT
[Interface]
PrivateKey = $PEER_PRIVATE_KEY
Address = $PEER_IP/32
DNS = 1.1.1.1

[Peer]
PublicKey = $SERVER_PUBLIC_KEY
Endpoint = $ENDPOINT_HOST:$ENDPOINT_PORT
AllowedIPs = 10.20.0.0/16, 10.44.0.0/24
PersistentKeepalive = 25
WGCLIENT

sudo systemctl restart wg-quick@wg0

echo
echo "Warehouse WireGuard user created."
echo "Peer name: $PEER_NAME"
echo "Peer VPN IP: $PEER_IP"
echo "Config path: $PEER_DIR/$PEER_NAME.conf"
echo
echo "Scan this QR code from Android WireGuard app:"
echo

sudo qrencode -t ansiutf8 < "$PEER_DIR/$PEER_NAME.conf"