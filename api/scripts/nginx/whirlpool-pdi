server {
    listen 80 default_server;
    server_name whirlpool-pdi-prod.scoptanalytics.in _;

    return 301 https://whirlpool-pdi-prod.scoptanalytics.in$request_uri;
}


server {
    server_name whirlpool-pdi-prod.scoptanalytics.in; # managed by Certbot

    # VPN/private network only
    allow 10.44.0.0/22;
    allow 10.20.0.0/16;
    deny all;

    # Custom VPN access error page.
    error_page 403 /_errors/vpn-required/index.html;

    # Serve public error page assets.
    location ^~ /_errors/ {
        allow all;
        alias /var/www/nginx-errors/;
        access_log off;
        expires 1h;
    }

    # Headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;

    error_page 405 = @method_not_allowed;

    if ($request_method = TRACE) {
      return 405;
    }

    if ($scheme != "https") {
      rewrite ^ https://$host$request_uri permanent;
    }

    location @method_not_allowed {
      add_header Allow "GET, POST, PUT, PATCH, DELETE, OPTIONS, HEAD" always;
      add_header X-Frame-Options "DENY" always;
      add_header X-Content-Type-Options "nosniff" always;
      return 405;
    }

    location ~ /.well-known {
      auth_basic off;
      allow all;
    }

    # Sensitive files
    location ~* ^/(?:\.env|\.git|\.svn|\.hg|\.bzr|composer\.(?:json|lock)|package-lock\.json|pnpm-lock\.yaml|yarn\.lock|Dockerfile|docker-compose\.ya?ml|backup|backups|dump|database|db|config|settings|secrets)(?:/|$) {
      return 404;
    }

    # Block backup, database, archive, env, and source files
    location ~* \.(?:sql|sqlite|db|bak|backup|old|orig|save|zip|tar|tgz|gz|bz2|xz|zst|7z|rar|env|ini|log|pem|key|crt|conf|yml|yaml|toml|lock)$ {
        return 404;
    }

    root /home/scoptanalytics-whirlpool/htdocs/whirlpool.scoptanalytics.in;
    index index.html;

    location / {
      allow 10.44.0.0/22;
      allow 10.20.0.0/16;
      deny all;
      
      proxy_pass http://127.0.0.1:8210/;
      proxy_http_version 1.1;

      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Forwarded-Proto $scheme;
      proxy_set_header X-Forwarded-Host $host;
      proxy_set_header X-Forwarded-Server $host;

      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "Upgrade";

      proxy_pass_request_headers on;

      proxy_connect_timeout 900;
      proxy_send_timeout 900;
      proxy_read_timeout 900;

      proxy_buffer_size 128k;
      proxy_buffers 4 256k;
      proxy_busy_buffers_size 256k;
    }

    location /flower-admin/ {
        allow 10.44.0.0/22;
        allow 10.20.0.0/16;
        deny all;
        
        proxy_pass http://127.0.0.1:5555/;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;

        proxy_http_version 1.1;
    }

    location ^~ /uploads/ {
      allow 10.44.0.0/22;
      allow 10.20.0.0/16;
      deny all;
      
      alias /home/scoptanalytics-whirlpool/htdocs/whirlpool.scoptanalytics.in/uploads/;

      autoindex off;
      expires 30d;
      access_log off;

      add_header X-Frame-Options "DENY" always;
      add_header X-Content-Type-Options "nosniff" always;
    }


    listen 443 ssl http2; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/whirlpool-pdi-prod.scoptanalytics.in/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/whirlpool-pdi-prod.scoptanalytics.in/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}


server {
    if ($host = whirlpool-pdi-prod.scoptanalytics.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80 ;
    server_name whirlpool-pdi-prod.scoptanalytics.in;
    return 404; # managed by Certbot
}