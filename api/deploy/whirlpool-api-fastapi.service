[Unit]
Description=Whirlpool API FastAPI
After=redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=whirlpool
Group=whirlpool
WorkingDirectory=/opt/whirlpool/api
EnvironmentFile=/etc/whirlpool/api.env
ExecStart=/opt/whirlpool/api/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8210 --workers 4
Restart=on-failure

[Install]
WantedBy=multi-user.target
