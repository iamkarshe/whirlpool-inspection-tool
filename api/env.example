# PostgreSQL Database
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=5432

# [dev, prod]
APP_ENV=dev

# Origin
APP_ORIGIN=
APP_CORS_ORIGINS=

# Logging
LOG_LEVEL=INFO

# JWT Secret
JWT_SECRET=

# Maximum inspection distance from warehouse
MAX_INSPECTION_DISTANCE_KM_FROM_WAREHOUSE=5

# Origin
APP_ORIGIN=whirlpool.scoptanalytics.in 

# Media type [local, s3]
MEDIA_TYPE=local

# Pre-signed S3 GET URL lifetime in seconds
MEDIA_PRESIGNED_URL_TTL_SECONDS=600

# Media base URL
MEDIA_BASE_URL=

# Frontend base URL
FRONTEND_BASE_URL=

# VAPID applicationServerKey returned to the browser.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_PATH=mod/push_notification/vapid_keys/private_key.pem
VAPID_SUBJECT=mailto:utkarshkumar.raut@scoptanalytics.com

# Auth rate limiting
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=1800

# Redis URL
REDIS_URL=

# IP geolocation for login audit (Celery task resolve_ip_metadata)
IP_GEO_LOOKUP_ENABLED=true
# Default provider: ip-api.com (HTTP). Override for another service, use {ip} placeholder.
IP_GEO_LOOKUP_URL=http://ip-api.com/json/{ip}?fields=status,message,country,countryCode,regionName,city,isp,query
# Max IPs enqueued per resolve_pending_ip_metadata cron/beat run (ip-api free tier ~45/min)
IP_GEO_BATCH_LIMIT=40
# Celery beat interval for resolve_pending_ip_metadata (seconds, default 1 hour)
RESOLVE_IP_METADATA_BEAT_INTERVAL_SECONDS=3600

# Celery result backend 
CELERY_RESULT_BACKEND_URL=

# Allow multiple logins from the same user
ALLOW_MULTI_LOGIN=

# Login via VPN only
LOGIN_VPN_IP=

# VPN Provision Server
VPN_PROVISION_SERVER=
VPN_PROVISION_KEY=

# Cron jobs 
JOB_EXECUTE_TOKEN=
AUTO_APPROVE_INSPECTION_HOURS=6

# Flower Admin Authentication
FLOWER_BASIC_AUTH=celery:

# Critical Admin Delete Token
CRITICAL_ADMIN_DELETE_TOKEN=

# IP Geolocation
IP_GEO_LOOKUP_ENABLED=true
IP_GEO_LOOKUP_URL=http://ip-api.com/json/{ip}?fields=status,message,country,countryCode,regionName,city,isp,query

# KPI parameter dropdown cache
KPI_PARAMETERS_CACHE_TTL_SECONDS=3600