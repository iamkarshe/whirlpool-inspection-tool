# PostgreSQL Database
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=5432

# [dev, prod]
APP_ENV=dev

# Logging
LOG_LEVEL=INFO

# JWT Secret
JWT_SECRET=

# Maximum inspection distance from warehouse
MAX_INSPECTION_DISTANCE_KM_FROM_WAREHOUSE=5

# Origin
APP_ORIGIN=whirlpool.scoptanalytics.in 

# Media type [local, s3]
MEDIA_TYPE=local

# Pre-signed S3 GET URL lifetime in seconds (default 600 = 10 minutes)
MEDIA_PRESIGNED_URL_TTL_SECONDS=600

# Media base URL (local mode: public URL prefix for /uploads paths)
MEDIA_BASE_URL=

# Frontend base URL
FRONTEND_BASE_URL=

# VAPID applicationServerKey returned to the browser.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_PATH=mod/push_notification/vapid_keys/private_key.pem
VAPID_SUBJECT=mailto:utkarshkumar.raut@scoptanalytics.com

# Auth rate limiting
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=1800

# Redis URL
REDIS_URL=

# Allow multiple logins from the same user
ALLOW_MULTI_LOGIN=

# Login via VPN only
LOGIN_VPN_IP=

# VPN Provision Server
VPN_PROVISION_SERVER=
VPN_PROVISION_KEY=